# URL base da API do agente GMT (FastAPI) — exposta ao browser (widget do chat)
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000

# --- Dashboard interno (/dashboard) — variáveis SÓ do servidor (não usar NEXT_PUBLIC) ---
# URL do backend usada pelo dashboard no servidor (fallback: NEXT_PUBLIC_AGENT_API_URL).
AGENT_API_URL=http://localhost:8000

# Token administrativo enviado ao backend em X-Admin-Token. DEVE ser igual ao
# ADMIN_API_TOKEN do backend. Gere um valor longo e aleatório (ex.: openssl rand -hex 32).
ADMIN_API_TOKEN=

# Palavra-passe do gate de login do dashboard.
DASHBOARD_PASSWORD=

# Valor do cookie de sessão do dashboard (segredo aleatório; ex.: openssl rand -hex 32).
DASHBOARD_SESSION_TOKEN=

# Opcional: CSP custom do Next.js (se vazio, usa padrão seguro definido em next.config.ts).
# NEXT_PUBLIC_CSP=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https:; form-action 'self'
