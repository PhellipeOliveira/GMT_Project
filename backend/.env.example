# =============================================================================
# Agente GMT — variáveis de ambiente (copie para .env e preencha)
# =============================================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# --- OpenAI (obrigatório) ---
# Onde criar: https://platform.openai.com/api-keys
# Descrição: chave da API OpenAI usada pelo parser, planner e subgrafos ReAct.
OPENAI_API_KEY=

# Modelo padrão (gpt-4o-mini é econômico para dev; ajuste em produção se quiser)
AGENT_MODEL_DEFAULT=gpt-4o-mini

# --- Modelos LLM por tarefa ---
# O backend Python lê LLM_MODEL_DEFAULT e LLM_MODEL_FINALIZER.
# A variável AGENT_MODEL não é lida pelo backend Python — é mantida apenas para referência do frontend.
#
# Fase 1 (Receção Digital): modelo rápido, sem reasoning pesado
LLM_MODEL_DEFAULT=gpt-4o-mini
LLM_MODEL_FINALIZER=gpt-4o-mini
LLM_TEMPERATURE_DEFAULT=0.2
LLM_TEMPERATURE_FINALIZER=0.2
#
# Fase 2 (Agente Comercial — projeto separado):
# LLM_MODEL_DEFAULT=gpt-4o              # tarefas de orçamento/nutrição
# LLM_MODEL_FINALIZER=gpt-4o-mini       # respostas finais
#
# Modelos com reasoning (gpt-5 family) — usam effort/verbosity em vez de temperature:
# LLM_EFFORT_DEFAULT=low
# LLM_VERBOSITY_DEFAULT=low

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_DB_URL=

# Alternativa (se preferir variáveis separadas em vez da URI):
# DB_HOST=db.xxxxx.supabase.co
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=postgres
# DB_PORT=5432
# DB_SSLMODE=require

# --- Resend (e-mail) ---
# Onde criar: https://resend.com/api-keys → Create API Key
# Descrição: envia confirmações ao visitante e alertas à equipe GMT.
# Domínio: Resend → Domains → verifique seu domínio antes de enviar em produção.
RESEND_API_KEY=

# Remetente verificado no Resend (ex.: no-reply@gmt.marketing após verificar o domínio)
RESEND_FROM_EMAIL=no-reply@seudominio.com
GMT_EMAIL_EQUIPE=contato@phellipeoliveira.org

# --- LangSmith (observabilidade — opcional) ---
# Onde criar: https://smith.langchain.com → Settings → API Keys
# Descrição: rastreia execuções do agente (traces) para debug e avaliação.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente-gmt

# --- Google Calendar (push one-way — opcional) ---
# Service Account. Onde criar: Google Cloud Console → APIs & Services → Credentials.
# Duas formas de fornecer a chave (a primeira que existir é usada):
#  1) GOOGLE_SERVICE_ACCOUNT_JSON — cole o CONTEÚDO do JSON (recomendado no Render).
#  2) GOOGLE_SERVICE_ACCOUNT_FILE — caminho do arquivo .json em disco (uso local).
# No Render com Secret File, aponte para o caminho absoluto (ex.: /etc/secrets/...).
# GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google_service_account.json

# ID real da agenda compartilhada (NÃO use "primary" com Service Account em produção).
GOOGLE_CALENDAR_ID=primary

# Convidar o lead como attendee no evento? Requer Domain-Wide Delegation.
# Deixe false até a delegação estar configurada (senão o Google recusa o convite).
GOOGLE_CALENDAR_INVITE_ATTENDEES=false

# Controla se o widget do agente aparece no site
# true = agente visível | false = agente oculto
AGENT_WIDGET_ENABLED=true

# --- Segurança / CORS / Rate limiting ---
# Domínios permitidos (CORS), separados por vírgula. Vazio = "*" (só p/ dev local).
# Ex.: CORS_ORIGINS=https://gmt.marketing,https://www.gmt.marketing
CORS_ORIGINS=


# Confiar nos headers de proxy (Render/Cloudflare): usar true em produção.
TRUST_PROXY_HEADERS=true

# Headers de segurança HTTP
SECURITY_HEADERS_ENABLED=true
SECURITY_ENABLE_HSTS=true
SECURITY_HSTS_MAX_AGE=31536000



# Rate limiting do endpoint /chat e /stream (proteção básica anti-abuso).
RATE_LIMIT_ENABLED=true

# Compat legado: limite base por minuto (usado como fallback).
RATE_LIMIT_PER_MIN=30

# Recomendado (Render produção, 1 instância):
# - chat: 30 req/min por IP
# - stream: 12 req/min por IP (se habilitado)
# - links de ação por e-mail: 10 req/10min por IP
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_STREAM_PER_MIN=12
RATE_LIMIT_MEETING_ACTION_PER_10MIN=10
RATE_LIMIT_WINDOW_SEC=60

# Tamanho máximo (caracteres) aceito no campo "input" do /chat.
CHAT_INPUT_MAX_CHARS=4000

# Segurança de streaming (SSE): desativado por padrão.
STREAM_ENDPOINT_ENABLED=false

# Links seguros de cancelamento/reagendamento via e-mail
# Base pública do backend usada para montar links (ex.: https://api.gmt.marketing)
PUBLIC_API_BASE_URL=http://localhost:8000

# Segredo HMAC para assinar links de ação de reunião (gere valor aleatório forte)
MEETING_ACTION_TOKEN_SECRET=

# Expiração do link em segundos (default 48h)
MEETING_ACTION_TOKEN_TTL_SEC=172800

# Link de reagendamento (cal.com)
CAL_COM_LINK=https://cal.com/phellipe-oliveira-ncbgsl/30min

# --- Dashboard interno (admin) ---
# Token compartilhado exigido no header X-Admin-Token dos endpoints /admin/*.
# DEVE ser igual ao ADMIN_API_TOKEN configurado no frontend (Vercel). Gere um valor
# longo e aleatório (ex.: openssl rand -hex 32). Sem ele, /admin/* responde 503.
ADMIN_API_TOKEN=

# --- Render (produção — configurar no painel Render, não só no .env local) ---
# No Render Web Service → Environment, replique OPENAI_API_KEY, SUPABASE_DB_URL,
# RESEND_* e GMT_EMAIL_EQUIPE. Render injeta PORT automaticamente.
# Start command: uvicorn app.server.webapp:app --host 0.0.0.0 --port $PORT

# --- Frontend (Next.js — .env.local na raiz do monorepo, não aqui) ---
# NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000
