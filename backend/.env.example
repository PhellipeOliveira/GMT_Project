# =============================================================================
# Agente GMT — variáveis de ambiente (copie para .env e preencha)
# =============================================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Controla se o widget do agente aparece no site
# true = agente visível | false = agente oculto
AGENT_WIDGET_ENABLED=true

# --- OpenAI (obrigatório) ---
# Onde criar: https://platform.openai.com/api-keys
# Descrição: chave da API OpenAI usada pelo parser, planner e subgrafos ReAct.
OPENAI_API_KEY=

# Modelo padrão (gpt-4o-mini é econômico para dev; ajuste em produção se quiser)
AGENT_MODEL=gpt-4o-mini

# --- LangSmith (observabilidade — opcional) ---
# Onde criar: https://smith.langchain.com → Settings → API Keys
# Descrição: rastreia execuções do agente (traces) para debug e avaliação.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente-gmt

# --- Supabase / Postgres (obrigatório para tools) ---
# IMPORTANTE: SUPABASE_URL + SUPABASE_KEY são da REST API (SDK JS).
# O backend Python conecta direto ao Postgres — use SUPABASE_DB_URL abaixo.
#
# Onde criar: Supabase → Project Settings → Database → Connection string → URI
# Escolha "Session pooler" ou "Direct connection" (copie a URI completa).
# Formato: postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# Alternativa (se preferir variáveis separadas em vez da URI):
# DB_HOST=db.xxxxx.supabase.co
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=postgres
# DB_PORT=5432
# DB_SSLMODE=require

# REST API (opcional — só se usar supabase-py no futuro; tools atuais NÃO usam)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_KEY=eyJ...

# --- Resend (e-mail) ---
# Onde criar: https://resend.com/api-keys → Create API Key
# Descrição: envia confirmações ao visitante e alertas à equipe GMT.
# Domínio: Resend → Domains → verifique seu domínio antes de enviar em produção.
RESEND_API_KEY=
# Remetente verificado no Resend (ex.: no-reply@gmt.marketing após verificar o domínio)
RESEND_FROM_EMAIL=no-reply@seudominio.com
GMT_EMAIL_EQUIPE=contato@phellipeoliveira.org

# --- Google Calendar (push one-way — opcional) ---
# Service Account (JSON key file). Não versione o arquivo (fica em backend/secrets/).
# Onde criar: Google Cloud Console → APIs & Services → Credentials → Service Account.
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google_service_account.json
GOOGLE_CALENDAR_ID=primary
# Convidar o lead como attendee no evento? Requer Domain-Wide Delegation.
# Deixe false até a delegação estar configurada (senão o Google recusa o convite).
GOOGLE_CALENDAR_INVITE_ATTENDEES=false

# --- Render (produção — configurar no painel Render, não só no .env local) ---
# No Render Web Service → Environment, replique OPENAI_API_KEY, SUPABASE_DB_URL,
# RESEND_* e GMT_EMAIL_EQUIPE. Render injeta PORT automaticamente.
# Start command: uvicorn app.server.webapp:app --host 0.0.0.0 --port $PORT

# --- Frontend (Next.js — .env.local na raiz do monorepo, não aqui) ---
# NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000
